<% content_for :title, "Login" %>

<div class="auth-shell">
  <section class="auth-panel auth-panel--brand">
    <p class="auth-eyebrow">Minecraft Control Plane</p>
    <h1>Single-port publishing for servers your team actually uses.</h1>
    <p class="auth-copy">
      Sign in to manage owned servers, shared environments, route visibility, and the exact
      <code>hostname:port</code>
      players should connect to.
    </p>

    <ul class="auth-feature-list">
      <li>Owner and member visibility is isolated per server.</li>
      <li>Published endpoints stay aligned with the shared mc-router contract.</li>
      <li>Operational status and routing stay aligned in one control plane.</li>
    </ul>
  </section>

  <section class="auth-panel auth-panel--form">
    <div class="auth-card">
      <div class="auth-card__header">
        <p class="auth-kicker">Login</p>
        <h2>Sign in</h2>
        <p>Use your account email and password to enter the control plane.</p>
      </div>

      <% if flash[:alert] %>
        <div class="auth-flash auth-flash--alert"><%= flash[:alert] %></div>
      <% end %>

      <% if flash[:notice] %>
        <div class="auth-flash auth-flash--notice"><%= flash[:notice] %></div>
      <% end %>

      <%= form_with url: login_path, class: "auth-form" do |form| %>
        <div class="auth-field">
          <%= form.label :email_address, "Email address" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "you@example.com", value: params[:email_address] %>
        </div>

        <div class="auth-field">
          <div class="auth-field__label_row">
            <%= form.label :password, "Password" %>
            <%= link_to "Forgot password?", new_password_path, class: "auth-inline-link" %>
          </div>
          <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72 %>
        </div>

        <%= form.submit "Sign in", class: "auth-submit" %>
      <% end %>
    </div>
  </section>
</div>
