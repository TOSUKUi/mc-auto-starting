<% content_for :title, "ログイン" %>

<div class="auth-shell">
  <div class="auth-header">
    <div class="auth-header__brand">
      <p class="auth-eyebrow">Minecraft サーバー</p>
      <h1>ログイン</h1>
      <p class="auth-copy">Minecraft サーバーの作成と管理を行います。招待済みの Discord アカウントで続行します。</p>
    </div>
  </div>

  <div class="auth-card">
    <% if flash[:alert] %>
      <div class="auth-flash auth-flash--alert"><%= flash[:alert] %></div>
    <% end %>

    <% if flash[:notice] %>
      <div class="auth-flash auth-flash--notice"><%= flash[:notice] %></div>
    <% end %>

    <div class="auth-form">
      <%= link_to "Discordでログイン", discord_login_path, class: "auth-submit" %>
    </div>
  </div>
</div>
