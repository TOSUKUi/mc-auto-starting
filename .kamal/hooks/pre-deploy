#!/usr/bin/env bash
set -euo pipefail

required_vars=(
  KAMAL_IMAGE
  KAMAL_REGISTRY_USERNAME
  APP_BASE_URL
  DEPLOY_WEB_HOST
  MINECRAFT_PUBLIC_DOMAIN
  MINECRAFT_PUBLIC_PORT
)

missing=()

for var_name in "${required_vars[@]}"; do
  if [[ -z "${!var_name:-}" ]]; then
    missing+=("${var_name}")
  fi
done

if [[ "${#missing[@]}" -gt 0 ]]; then
  printf 'Missing required deploy environment: %s\n' "${missing[*]}" >&2
  exit 1
fi

if [[ ! -f ".kamal/secrets-common" && ! -f ".kamal/secrets.production" ]]; then
  echo "Missing Kamal secrets files. Copy .kamal/secrets-common.example and .kamal/secrets.production.example first." >&2
  exit 1
fi

if [[ ! -f "docker/mc-router/deploy.compose.yml" ]]; then
  echo "Missing docker/mc-router/deploy.compose.yml helper." >&2
  exit 1
fi
