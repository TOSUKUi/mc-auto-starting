#!/usr/bin/env bash
set -euo pipefail

network_name="mc_router_net"
router_container_name="mc-router"
router_image="itzg/mc-router"
router_host_config_dir="${MC_ROUTER_HOST_CONFIG_DIR:-/var/lib/mc-auto-starting/shared/mc-router}"
public_port="${MINECRAFT_PUBLIC_PORT:?MINECRAFT_PUBLIC_PORT is required}"
ssh_user="${SSH_USER:?SSH_USER is required}"
deploy_host="${DEPLOY_WEB_HOST:?DEPLOY_WEB_HOST is required}"
app_image="${KAMAL_IMAGE:?KAMAL_IMAGE is required}"

ssh "${ssh_user}@${deploy_host}" \
  NETWORK_NAME="${network_name}" \
  ROUTER_CONTAINER_NAME="${router_container_name}" \
  ROUTER_IMAGE="${router_image}" \
  ROUTER_HOST_CONFIG_DIR="${router_host_config_dir}" \
  PUBLIC_PORT="${public_port}" \
  APP_IMAGE="${app_image}" \
  'bash -se' <<'EOF'
set -euo pipefail

docker network inspect "${NETWORK_NAME}" >/dev/null 2>&1 || docker network create "${NETWORK_NAME}" >/dev/null

mkdir -p "${ROUTER_HOST_CONFIG_DIR}"
touch "${ROUTER_HOST_CONFIG_DIR}/routes.json"

existing_router_id="$(docker ps -aq --filter "name=^/${ROUTER_CONTAINER_NAME}$")"

if [[ -n "${existing_router_id}" ]]; then
  existing_router_image="$(docker inspect --format '{{.Config.Image}}' "${existing_router_id}")"
  existing_router_port="$(docker inspect --format '{{with index .HostConfig.PortBindings "25565/tcp"}}{{(index . 0).HostPort}}{{end}}' "${existing_router_id}")"
  existing_router_component_label="$(docker inspect --format '{{index .Config.Labels "app.kubos.dev/component"}}' "${existing_router_id}")"

  if [[ "${existing_router_image}" != "${ROUTER_IMAGE}" || "${existing_router_port}" != "${PUBLIC_PORT}" || "${existing_router_component_label}" != "mc-router" ]]; then
    docker rm -f "${ROUTER_CONTAINER_NAME}" >/dev/null
    existing_router_id=""
  fi
fi

if [[ -z "${existing_router_id}" ]]; then
  docker run -d \
    --name "${ROUTER_CONTAINER_NAME}" \
    --restart unless-stopped \
    --label app.kubos.dev/component=mc-router \
    --network "${NETWORK_NAME}" \
    -e PORT=25565 \
    -e ROUTES_CONFIG=/config/routes.json \
    -v "${ROUTER_HOST_CONFIG_DIR}:/config" \
    -p "${PUBLIC_PORT}:25565" \
    "${ROUTER_IMAGE}" >/dev/null
else
  router_networks="$(docker inspect --format '{{json .NetworkSettings.Networks}}' "${ROUTER_CONTAINER_NAME}")"

  if [[ "${router_networks}" != *"\"${NETWORK_NAME}\":"* ]]; then
    docker network connect "${NETWORK_NAME}" "${ROUTER_CONTAINER_NAME}"
  fi

  if [[ "$(docker inspect --format '{{.State.Running}}' "${ROUTER_CONTAINER_NAME}")" != "true" ]]; then
    docker start "${ROUTER_CONTAINER_NAME}" >/dev/null
  fi
fi

app_container_ids="$(docker ps -q --filter "ancestor=${APP_IMAGE}")"

if [[ -z "${app_container_ids}" ]]; then
  echo "warning: no running app containers found for image ${APP_IMAGE}" >&2
fi

for app_container_id in ${app_container_ids}; do
  app_networks="$(docker inspect --format '{{json .NetworkSettings.Networks}}' "${app_container_id}")"

  if [[ "${app_networks}" != *"\"${NETWORK_NAME}\":"* ]]; then
    docker network connect "${NETWORK_NAME}" "${app_container_id}"
  fi
done
EOF

cat <<'EOF'
Kamal deploy completed.

Reconciled host runtime prerequisites:
  - ensured mc_router_net exists
  - ensured long-lived mc-router sibling service is running
  - attached current app container(s) to mc_router_net

The app expects mc-router to keep the label:
  app.kubos.dev/component=mc-router
EOF
