# Required local Compose baseline
LOCAL_UID=1000
LOCAL_GID=1000
DOCKER_GID=999

# Required local database baseline
DB_HOST=db
DB_PORT=3306
DB_USERNAME=app_user
DB_PASSWORD=change-me-db-password
DB_ROOT_PASSWORD=change-me-root-password
DB_NAME_DEVELOPMENT=app_development
DB_NAME_TEST=app_test
DB_NAME_PRODUCTION=app_production

# Required Docker + router baseline
DOCKER_ENGINE_SOCKET_PATH=/var/run/docker.sock
DOCKER_ENGINE_OPEN_TIMEOUT=5
DOCKER_ENGINE_READ_TIMEOUT=30
DOCKER_ENGINE_WRITE_TIMEOUT=30

MINECRAFT_PUBLIC_DOMAIN=mc.example.test
MINECRAFT_PUBLIC_PORT=25565
MINECRAFT_RUNTIME_IMAGE=itzg/minecraft-server
MINECRAFT_RUNTIME_NETWORK_NAME=mc_router_net

MC_ROUTER_IMAGE=itzg/mc-router
MC_ROUTER_ROUTES_CONFIG_PATH=/app/tmp/mc-router/routes.json
MC_ROUTER_RELOAD_STRATEGY=docker_signal
MC_ROUTER_RELOAD_SIGNAL=HUP
MC_ROUTER_RELOAD_CONTAINER_LABELS=app.kubos.dev/component=mc-router

# Required bootstrap-owner baseline
BOOTSTRAP_DISCORD_USER_ID=123456789012345678
BOOTSTRAP_DISCORD_USERNAME=server-owner
BOOTSTRAP_EMAIL_ADDRESS=owner@example.test

# Optional Discord OAuth login
# DISCORD_CLIENT_ID=123456789012345678
# DISCORD_CLIENT_SECRET=change-me-discord-client-secret
# APP_BASE_URL=http://localhost:3000

# Optional Docker override
# DOCKER_ENGINE_API_VERSION=v1.47
# MINECRAFT_RUNTIME_VANILLA_IMAGE=itzg/minecraft-server:java21
# MINECRAFT_RUNTIME_VANILLA_VERSION_MANIFEST_URL=https://piston-meta.mojang.com/mc/game/version_manifest_v2.json
# MINECRAFT_RUNTIME_PAPER_VERSION_MANIFEST_URL=https://qing762.is-a.dev/api/papermc
# MINECRAFT_RUNTIME_VERSION_OPTIONS_CACHE_TTL=300

# Optional router integrations
# MC_ROUTER_RELOAD_COMMAND=bash -lc 'kill -HUP 1'
# MC_ROUTER_API_URL=http://mc-router:8080

# Optional Discord bot integration
# DISCORD_BOT_TOKEN=change-me-discord-bot-token
# DISCORD_BOT_PUBLIC_KEY=change-me-discord-bot-public-key
# DISCORD_BOT_APPLICATION_ID=123456789012345678
# DISCORD_BOT_SHARED_SECRET=change-me-bot-shared-secret

RAILS_LOG_LEVEL=info
