# Required local Compose baseline
LOCAL_UID=1000
LOCAL_GID=1000
DOCKER_GID=999

# Required local database baseline
DB_HOST=db
DB_PORT=3306
DB_USERNAME=app
DB_PASSWORD=password
DB_ROOT_PASSWORD=rootpassword
DB_NAME_DEVELOPMENT=mc_auto_starting_development
DB_NAME_TEST=mc_auto_starting_test

# Required public ingress baseline
MINECRAFT_PUBLIC_DOMAIN=mc.example.test
MINECRAFT_PUBLIC_PORT=25565

# Required Discord OAuth baseline
DISCORD_CLIENT_ID=123456789012345678
DISCORD_CLIENT_SECRET=change-me-discord-client-secret
APP_BASE_URL=http://localhost:3000

# Required first-owner bootstrap baseline
BOOTSTRAP_DISCORD_USER_ID=123456789012345678
BOOTSTRAP_DISCORD_USERNAME=server-owner

# Optional advanced overrides
# DOCKER_ENGINE_API_VERSION=v1.47
# MINECRAFT_RCON_PASSWORD_SECRET=change-me-stable-rcon-secret

# Optional internal Discord bot API
# DISCORD_BOT_API_TOKEN=change-me-internal-bot-api-token

RAILS_LOG_LEVEL=info
